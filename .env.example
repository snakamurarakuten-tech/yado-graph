# 楽天ウェブサービスのアプリID(必須) https://webservice.rakuten.co.jp/
RAKUTEN_APP_ID=
# 楽天アフィリエイトID(任意・設定すると各リンクがアフィリエイトURLになる)
# ★A-1: これを設定すると CTA が hb.afl.rakuten.co.jp のアフィリエイトリンクになり、
#   クリック時にCookieが付与される。未設定でも施設ページ(travel.rakuten.co.jp)へは飛ぶ。
RAKUTEN_AFFILIATE_ID=

# Instagram埋め込み(B-4)。ビジネス/クリエイターアカウント＋長期トークンが必要。
# 未設定なら詳細ページのSNS枠は自動的に非表示になる(画面は壊れない)。
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_IG_USER_ID=
INSTAGRAM_MIN_LIKES=30
INSTAGRAM_RECENT_MONTHS=12
INSTAGRAM_MAX_POSTS=9

# APIレスポンスのファイルキャッシュTTL(分)。0で無効化
CACHE_TTL_MINUTES=60

# クロスセル系の外部リンク(別アフィリエイト)。URL差し替えのみで反映される
RENTACAR_AFFILIATE_URL=https://travel.rakuten.co.jp/cars/
GASSHUKU_AFFILIATE_URL=#   # 合宿免許のアフィリURL(未整備。#のままだと詳細ページで非表示)
RENTACAR_AFFILIATE_URL=#    # レンタカーのアフィリURL(未整備。#のままだと非表示)

# 本番URL(canonical / OGP用)。末尾スラッシュなし
APP_URL=http://localhost:8000
APP_NAME=YADO GRAPH
APP_DEBUG=true

# クリック計測(P0-2)
GA4_MEASUREMENT_ID=          # GA4測定ID(任意)。設定するとカスタムイベントを送信
CLICK_LOG_ENABLED=true       # storage/logs/clicks-YYYY-MM-DD.jsonl への簡易ログ

# 一覧のレビュー欠損の扱い(P2-7)。true=レビュー0件を一覧から除外 / false=「レビューなし」表示
EXCLUDE_NO_REVIEW=true       # メモ2: クチコミ0件の宿を一覧・検索から除外(既定true)

# --- 掲載フィルタ・取り込み(メモ3 / 起動時自動シード) ---
RAKUTEN_SQUEEZE_CONDITION=   # 楽天APIの施設絞り込み(対応値の確認後に設定。未設定=無効)
SEED_MIN=20                  # 起動時: DBがこの件数未満ならフルシード
SEED_PAGES=3                 # シード時のカテゴリあたり取得ページ数
SEED_LIMIT=200               # シード時の詳細化上限
REFRESH_DAYS=7               # 最古データがこの日数を超えたら起動時に差分更新
REFRESH_LIMIT=100            # 差分更新の上限件数

# 自前DB(セクション2)。夜間バッチで取り込み、サイト表示はここを参照。
# 未設定なら storage/db/yado.sqlite。DBが空の間は自動でAPI直叩きにフォールバック。
DB_PATH=

# 周辺情報(セクション4)。aboutLeisureが空の宿のみOverpass(OSM)で補完。
SURROUNDINGS_ENABLED=true
OVERPASS_URL=https://overpass-api.de/api/interpreter
SURROUNDINGS_RADIUS_M=2500
SURROUNDINGS_MIN_SPOTS=3
SURROUNDINGS_MAX_SPOTS=8

# --- AI生成(特集・こだわり文)。ローカル実行専用・完全無料枠で運用 ---
GEMINI_API_KEY=              # https://aistudio.google.com/apikey で無料発行
GEMINI_MODEL=gemini-2.5-flash
SEARCH_PROVIDER=gemini       # 公式サイト発見の手段。既定gemini(CSE APIは新規閉鎖のため)
GROUNDING_DAILY_CAP=100      # グラウンディングの日次上限(無料枠保護)
GOOGLE_CSE_KEY=              # (旧)Custom Search JSON API。新規アカウントでは取得不可のため通常は空でOK
GOOGLE_CSE_CX=               # プログラム可能検索エンジンのID(cse.google.com で作成・ウェブ全体を検索をON)
NOTIFY_EMAIL=                # 自動生成の結果通知先(空なら storage/logs/notify.log のみ)
OFFICIAL_LIMIT=25            # 週次バッチでのこだわり生成上限(検索無料枠90/日の範囲)
OFFICIAL_RETRY_COOLDOWN_DAYS=30  # 公式HP発見に失敗した宿を再挑戦するまでの待機日数(指摘5)
OFFICIAL_RETRY_MAX=3         # 同一宿への最大試行回数(これを超えたら恒久スキップ)
OFFICIAL_REFRESH_DAYS=0      # 生成済みこだわり文を公式HPから取り直す間隔。0=無効(指摘6)
