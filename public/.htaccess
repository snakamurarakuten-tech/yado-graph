Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # HTTPS へ統一(SEO・セキュリティ。mixhostのSSL証明書が有効な前提)
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP:X-Forwarded-Proto} !https
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # 実在するファイル(assets等)はそのまま返す
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L]
</IfModule>

# セキュリティヘッダー
<IfModule mod_headers.c>
    # MIMEタイプの推測を禁止
    Header always set X-Content-Type-Options "nosniff"
    # 他サイトへのiframe埋め込みを禁止(クリックジャッキング対策)
    Header always set X-Frame-Options "SAMEORIGIN"
    # リファラは同一オリジンには全量、外部にはオリジンのみ
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # 不要なブラウザ機能を無効化
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    # HSTS: HTTPS接続時のみ1年間強制
    Header always set Strict-Transport-Security "max-age=31536000" env=HTTPS
</IfModule>

# 静的アセットのブラウザキャッシュ(表示速度・Core Web Vitals)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    ExpiresByType image/x-icon "access plus 30 days"
    ExpiresByType font/woff2 "access plus 30 days"
    # HTMLはキャッシュさせない(評価・在庫が日々変わるため)
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# 圧縮(転送量削減)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml application/javascript application/json application/xml
</IfModule>
